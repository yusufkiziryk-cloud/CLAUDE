{
  "expo": {
    "name": "Refleks",
    "slug": "refleks-reflexology",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "refleks",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.refleks.reflexology",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sesli rehberli seanslar için mikrofon erişimi",
        "UIBackgroundModes": ["audio"],
        "NSUserNotificationUsageDescription": "Wellness hatırlatıcıları için bildirim izni"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "package": "com.refleks.reflexology",
      "versionCode": 1,
      "permissions": [
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C9885",
          "sounds": []
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Sesli rehber için"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
