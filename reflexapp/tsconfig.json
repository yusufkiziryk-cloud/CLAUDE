{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./components/*"],
      "@screens/*": ["./app/*"],
      "@stores/*": ["./stores/*"],
      "@constants/*": ["./constants/*"],
      "@types/*": ["./types/*"],
      "@hooks/*": ["./hooks/*"],
      "@services/*": ["./services/*"],
      "@database/*": ["./database/*"]
    }
  }
}
